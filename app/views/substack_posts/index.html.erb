<%# Implicit template lookup: SubstackPostsController#index renders this file.
    Rails resolves app/views/substack_posts/index.html.erb automatically. %>
<% content_for :title, "Idea feed" %>

<%# turbo_stream_from renders a <turbo-cable-stream-source> element that opens
    an Action Cable subscription to this (signed) stream name. When
    FetchSubstackSourceJob broadcasts to the same name, Turbo applies the
    <turbo-stream> action it receives — here, replacing #substack_feed with a
    freshly rendered _feed partial. Scoped per user so nobody receives anyone
    else's feed. %>
<%= turbo_stream_from "substack_feed_#{current_user.id}" %>

<div class="min-h-screen">
  <div class="px-7 pt-8">

    <%# Page header: big headline left, refresh + manage sources right. %>
    <div class="flex justify-between items-end gap-4">
      <h1 class="cf-headline text-[clamp(72px,13vw,120px)]">
        IDEA<br>FEED
      </h1>

      <div class="shrink-0 flex flex-col items-end gap-3 pb-2">
        <%# Refresh is a POST to the collection route /substack_posts/refresh.
            We use form_with (not link_to) because it must be a POST, not a GET.
            data-turbo-submits-with is built into Turbo: once the submission has
            actually started it swaps the button label to this text and disables
            the button, then restores it when the response renders. (Disabling
            the button ourselves in a click handler would run *before* the
            browser submits the form — and a disabled button can't submit, so
            the request would never be sent.) %>
        <%= form_with url: refresh_substack_posts_path, method: :post do |f| %>
          <%= f.submit "refresh",
                data: { turbo_submits_with: "refreshing..." },
                class: "cf-action font-normal bg-transparent border-0 cursor-pointer hover:text-[var(--cf-orange)] transition-colors duration-150" %>
        <% end %>

        <%= link_to "manage sources", substack_sources_path,
              class: "cf-meta hover:text-black transition-colors duration-150" %>
      </div>
    </div>

    <%# Shared with FetchSubstackSourceJob's broadcast — see _feed.html.erb. %>
    <%= render "feed", posts: @posts, sources: @sources %>
  </div>
</div>
